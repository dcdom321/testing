# Copy to .env and fill in. Bots read these env vars when the matching
# *_env field is set in config (weatherbot config.json or copybot config.yaml).
# Loaded by systemd via EnvironmentFile= or by docker-compose env_file:.

# Wallet (used by both weatherbot and copybot when live/real trading is on)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Copybot — required to actually place real trades. Both this AND
# real_trading_enabled: true in copybot/config.yaml must be set.
REAL_TRADING_ENABLED=false

# Copybot notifications (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
